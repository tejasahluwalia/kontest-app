{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "moduleResolution": "node" ,
    "paths": {
      "@web": ["./apps/web/src"],
      "@web/*": ["./apps/web/src/*"],
      "@api": ["./apps/api/src"],
      "@api/*": ["./apps/api/src/*"],
    }
  }
}
