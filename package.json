{
	"name": "kontest-app",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev:server": "bun run --watch server/src/index.ts",
		"dev:client": "bunx --bun vite dev client --host",
		"dev:db-up": "docker compose -f docker/docker-compose.yml up -d",
		"dev:db-down": "docker compose -f docker/docker-compose.yml down",
		"build:client": "bunx --bun vite build client",
		"build:server": "bun build server/src/index.ts --target bun --outdir ./server/dist",
		"start:server": "NODE_ENV=production bun server/dist/index.js",
		"preview:client": "bunx --bun vite preview client",
		"serve": "bun serve"
	},
	"devDependencies": {
		"@biomejs/biome": "2.0.5",
		"@tanstack/router-plugin": "^1.121.37",
		"@tanstack/solid-router-devtools": "^1.121.34",
		"@types/bun": "latest",
		"@types/pg": "^8.15.4",
		"drizzle-kit": "^0.31.2",
		"tsx": "^4.20.3",
		"vite": "^7.0.0",
		"vite-plugin-solid": "^2.11.7"
	},
	"peerDependencies": {
		"typescript": "^5.8.2"
	},
	"dependencies": {
		"@corvu/otp-field": "^0.1.4",
		"@elysiajs/cors": "^1.3.3",
		"@elysiajs/eden": "^1.3.2",
		"@elysiajs/static": "^1.3.0",
		"@kobalte/core": "^0.13.10",
		"@kobalte/tailwindcss": "^0.9.0",
		"@paralleldrive/cuid2": "^2.2.2",
		"@tailwindcss/vite": "^4.1.10",
		"@tanstack/solid-form": "^1.12.3",
		"@tanstack/solid-router": "^1.121.34",
		"better-auth": "^1.2.10",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cva": "^1.0.0-beta.4",
		"dotenv": "^16.5.0",
		"drizzle-orm": "^0.44.2",
		"drizzle-typebox": "^0.3.3",
		"effect": "^3.16.9",
		"elysia": "^1.3.5",
		"lucide-solid": "^0.523.0",
		"nanoid": "^5.1.5",
		"pg": "^8.16.2",
		"solid-js": "^1.9.7",
		"tailwind-merge": "^3.3.1",
		"tailwindcss": "^4.1.10",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.3.4",
		"zod": "^3.25.67"
	},
	"override": {
		"@sinclair/typebox": "0.34.27"
	},
	"packageManager": "pnpm@10.12.3",
	"trustedDependencies": [
		"@biomejs/biome",
		"@tailwindcss/oxide"
	]
}
