{
  "name": "kontest-app",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:server": "bun run --watch server/src/index.ts",
    "dev:client": "bunx --bun vite dev client",
    "dev:db-up": "docker compose -f docker/docker-compose.yml up -d",
    "dev:db-down": "docker compose -f docker/docker-compose.yml down",
    "build:client": "bunx --bun vite build client",
    "build:server": "bun build server/src/index.ts --target bun --outdir ./server/dist",
    "start:server": "NODE_ENV=production bun server/dist/index.js",
    "preview:client": "bunx --bun vite preview client",
    "serve": "bun serve"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tanstack/router-plugin": "^1.120.12",
    "@tanstack/solid-router-devtools": "^1.120.12",
    "@types/bun": "latest",
    "@types/pg": "^8.15.2",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.6"
  },
  "peerDependencies": {
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@corvu/otp-field": "^0.1.4",
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/eden": "^1.3.2",
    "@elysiajs/static": "^1.3.0",
    "@kobalte/core": "^0.13.10",
    "@kobalte/tailwindcss": "^0.9.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/solid-form": "^1.12.0",
    "@tanstack/solid-router": "^1.120.10",
    "better-auth": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.0",
    "drizzle-typebox": "^0.3.3",
    "effect": "^3.16.2",
    "elysia": "^1.3.3",
    "lucide-solid": "^0.511.0",
    "nanoid": "^5.1.5",
    "pg": "^8.16.0",
    "solid-js": "^1.9.7",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.8",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.3.2",
    "zod": "^3.25.42"
  },
  "override": {
    "@sinclair/typebox": "0.34.27"
  },
  "packageManager": "pnpm@10.11.0"
}
